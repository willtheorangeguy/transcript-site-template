# Deploy workflow for a TRANSCRIPT REPO that contains this template in a `web/`
# subfolder alongside the year folders, e.g.:
#
#   your-podcast-repo/
#   ├── 2020/ ... 2026/      (year folders with *_transcript.* / *_summary.* files)
#   └── web/                 (this template)
#
# Copy this file into the transcript repo as
#   .github/workflows/deploy.yaml
# (drop the ".example" suffix), then enable Pages -> "GitHub Actions" in the
# repo settings. The build runs from web/, and the content loader reads the
# year folders from the parent directory (..), i.e. the repo root.
name: Deploy to GitHub Pages

on:
  push:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  build:
    name: Build
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: web
    steps:
      - uses: actions/checkout@v6

      - name: Set up Node.js
        uses: actions/setup-node@v6
        with:
          node-version: '22'
          cache: 'npm'
          cache-dependency-path: web/package-lock.json

      - name: Setup Pages
        id: pages
        uses: actions/configure-pages@v6

      - name: Install dependencies
        run: npm ci

      - name: Build site
        run: npm run build
        env:
          SITE: ${{ steps.pages.outputs.origin }}
          BASE_PATH: ${{ steps.pages.outputs.base_path }}

      - name: Upload artifact
        uses: actions/upload-pages-artifact@v5
        with:
          path: web/dist

  deploy:
    name: Deploy
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v5
