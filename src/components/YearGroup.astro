---
import type { Episode } from '../utils/episodes';

interface Props {
  year: number;
  episodes: Episode[];
}

const { year, episodes } = Astro.props;
---

<section class="year-group">
  <h2 class="year-heading">{year}</h2>
  <ul class="episode-list">
    {episodes.map((episode) => (
      <li class="episode-item">
        <a href={`/episodes/${episode.slug}`} class="episode-link">
          <span class="episode-date">
            {episode.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
          </span>
          <span class="episode-title">{episode.title}</span>
          {episode.youtubeUrl && (
            <svg class="youtube-icon" viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          )}
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .year-group {
    margin-bottom: var(--spacing-2xl);
  }

  .year-heading {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 2px solid var(--color-primary);
    display: inline-block;
  }

  .episode-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .episode-item {
    margin: 0;
    border-bottom: 1px solid var(--color-border);
  }

  .episode-item:last-child {
    border-bottom: none;
  }

  .episode-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-md) var(--spacing-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .episode-link:hover {
    background-color: var(--color-surface);
    text-decoration: none;
  }

  .episode-date {
    flex-shrink: 0;
    width: 60px;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .episode-title {
    flex: 1;
    font-weight: 500;
  }

  .youtube-icon {
    flex-shrink: 0;
    color: #ff0000;
  }

  @media (max-width: 640px) {
    .episode-link {
      flex-wrap: wrap;
    }
    
    .episode-date {
      width: auto;
      order: 2;
    }
    
    .episode-title {
      width: 100%;
      order: 1;
    }
    
    .youtube-icon {
      order: 3;
    }
  }
</style>
