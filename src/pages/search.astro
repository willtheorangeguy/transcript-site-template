---
import BaseLayout from '../layouts/BaseLayout.astro';
import Search from '../components/Search.astro';
---

<BaseLayout title="Search" description="Search all podcast episodes">
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Search Episodes</h1>
      <p class="page-description">Search through all episode transcripts and summaries</p>
    </header>

    <div class="search-page">
      <Search placeholder="Type to search..." />
      
      <div class="search-tips">
        <h3>Search Tips</h3>
        <ul>
          <li>Search finds matches in episode transcripts and summaries</li>
          <li>Use quotes for exact phrases: <code>"exact phrase"</code></li>
          <li>Results are ranked by relevance</li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .search-page {
    max-width: 600px;
    margin: 0 auto;
  }

  .search-tips {
    margin-top: var(--spacing-3xl);
    padding: var(--spacing-lg);
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
  }

  .search-tips h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-md);
  }

  .search-tips ul {
    list-style: disc;
    padding-left: var(--spacing-lg);
    margin: 0;
  }

  .search-tips li {
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-xs);
  }

  .search-tips code {
    background-color: var(--color-background);
    padding: 0.125em 0.375em;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
  }
</style>
